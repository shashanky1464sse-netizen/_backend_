# ── Formatter: convert to Alpaca-style instruction format ────────────────────
def make_sample(instruction: str, input_text: str, output: str) -> dict:
    return {
        "instruction": instruction.strip(),
        "input":       input_text.strip(),
        "output":      output.strip(),
    }
 
 
# ══════════════════════════════════════════════════════════════════════════════
#  FUNCTION 1 — evaluate_answer
# ══════════════════════════════════════════════════════════════════════════════
def gen_evaluate_answer(n: int) -> list:
    samples = []
    instruction = (
        "You are an expert technical interviewer. Evaluate the candidate's answer "
        "to the given interview question. Return a JSON object with keys: "
        "score (integer 0-100), strengths (list of strings), "
        "improvements (list of strings), suggestions (list of strings)."
    )
    for _ in tqdm(range(n), desc="evaluate_answer"):
        question = random.choice(SAMPLE_QUESTIONS)
        answer   = random.choice(SAMPLE_ANSWERS_GOOD + SAMPLE_ANSWERS_WEAK)
        skill    = random.choice(SKILLS)
        input_text = f"Question: {question}\nCandidate Answer: {answer}\nSkill: {skill}"
        try:
            raw = call(
                f"Generate a realistic evaluation JSON for this:\n{input_text}\n"
                "Return ONLY valid JSON with keys: score, strengths, improvements, suggestions.",
                system="You are an expert technical interviewer. Return only valid JSON."
            )
            # validate JSON parseable
            parsed = json.loads(raw.strip().strip("```json").strip("```"))
            samples.append(make_sample(instruction, input_text, json.dumps(parsed)))
            time.sleep(0.3)
        except Exception as e:
            print(f"  skip evaluate sample: {e}")
    return samples
 
 
# ══════════════════════════════════════════════════════════════════════════════
#  FUNCTION 2 — generate_questions
# ══════════════════════════════════════════════════════════════════════════════
def gen_generate_questions(n: int) -> list:
    samples = []
    instruction = (
        "You are a technical interviewer. Generate a realistic interview question plan "
        "based on the candidate's skills and experience. Return a JSON array of objects, "
        "each with keys: main_question, follow_up_question, category."
    )
    for _ in tqdm(range(n), desc="generate_questions"):
        primary    = random.choice(SKILLS)
        secondary  = random.choice([s for s in SKILLS if s != primary])
        weak       = random.choice([s for s in SKILLS if s not in [primary, secondary]])
        exp        = random.choice(EXPERIENCE)
        difficulty = random.choice(DIFFICULTIES)
        count      = random.randint(3, 6)
        input_text = (
            f"Primary skill: {primary}\nSecondary skill: {secondary}\n"
            f"Weak skill: {weak}\nExperience: {exp} years\n"
            f"Difficulty: {difficulty}\nNumber of questions: {count}"
        )
        try:
            raw = call(
                f"Generate {count} interview questions for this candidate profile:\n{input_text}\n"
                "Return ONLY a valid JSON array.",
                system="You are a technical interviewer. Return only valid JSON array."
            )
            parsed = json.loads(raw.strip().strip("```json").strip("```"))
            samples.append(make_sample(instruction, input_text, json.dumps(parsed)))
            time.sleep(0.3)
        except Exception as e:
            print(f"  skip gen_questions sample: {e}")
    return samples
 
 
# ══════════════════════════════════════════════════════════════════════════════
#  FUNCTION 3 — generate_single_question
# ══════════════════════════════════════════════════════════════════════════════
def gen_single_question(n: int) -> list:
    samples = []
    instruction = (
        "Generate exactly one new technical interview question different from the current one. "
        "Return a single JSON object with keys: main_question, follow_up_question, category."
    )
    for _ in tqdm(range(n), desc="generate_single_question"):
        skill           = random.choice(SKILLS)
        current_question = random.choice(SAMPLE_QUESTIONS)
        input_text = f"Skill: {skill}\nCurrent question (avoid repeating): {current_question}"
        try:
            raw = call(
                f"Generate one replacement interview question:\n{input_text}\n"
                "Return ONLY a valid JSON object.",
                system="You are a technical interviewer. Return only valid JSON."
            )
            parsed = json.loads(raw.strip().strip("```json").strip("```"))
            samples.append(make_sample(instruction, input_text, json.dumps(parsed)))
            time.sleep(0.3)
        except Exception as e:
            print(f"  skip single_question sample: {e}")
    return samples
 
 
# ══════════════════════════════════════════════════════════════════════════════
#  FUNCTION 4 — generate_interview_summary
# ══════════════════════════════════════════════════════════════════════════════
def gen_interview_summary(n: int) -> list:
    samples = []
    instruction = (
        "You are a technical interviewer. Write a professional 5-6 line summary "
        "of the candidate's overall interview performance. Return plain text only, "
        "no JSON, no markdown."
    )
    for _ in tqdm(range(n), desc="generate_interview_summary"):
        role   = random.choice(ROLES)
        skills = random.sample(SKILLS, 3)
        scores = [random.randint(40, 95) for _ in range(4)]
        avg    = sum(scores) // len(scores)
        input_text = (
            f"Candidate role: {role}\n"
            f"Skills tested: {', '.join(skills)}\n"
            f"Scores per question: {scores}\n"
            f"Average score: {avg}/100"
        )
        try:
            summary = call(
                f"Write a 5-6 line professional interview summary for:\n{input_text}",
                system="You are a senior technical interviewer writing performance reports."
            )
            samples.append(make_sample(instruction, input_text, summary))
            time.sleep(0.3)
        except Exception as e:
            print(f"  skip summary sample: {e}")
    return samples
 
 
