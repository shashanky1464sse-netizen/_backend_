        extra_years = random.randint(0, 3)
        input_text  = resume
        try:
            raw = call(
                f"Extract experience_years and target_role from this resume:\n{resume}\n"
                "Return ONLY valid JSON: {{\"experience_years\": int, \"target_role\": \"string\"}}",
                system="You are an HR recruiter. Return only valid JSON."
            )
            parsed = json.loads(raw.strip().strip("```json").strip("```"))
            samples.append(make_sample(instruction, input_text, json.dumps(parsed)))
            time.sleep(0.3)
        except Exception as e:
            print(f"  skip resume sample: {e}")
    return samples
 
 
