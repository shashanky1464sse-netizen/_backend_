#  FUNCTION 6 — ai_classify_unknown_skills
# ══════════════════════════════════════════════════════════════════════════════
def gen_classify_skills(n: int) -> list:
    samples = []
    instruction = (
        "Classify the given list of unknown terms from a resume into categories. "
        "Return a JSON object with keys: technical_skills, tools_frameworks, soft_skills "
        "(each is a list of strings). Only include terms in the most appropriate category."
    )
    for _ in tqdm(range(n), desc="ai_classify_unknown_skills"):
        terms      = random.choice(UNKNOWN_TERMS)
        extra      = random.sample(SKILLS, 2)
        all_terms  = terms + extra
        random.shuffle(all_terms)
        input_text = f"Unknown terms: {json.dumps(all_terms)}"
        try:
            raw = call(
                f"Classify these resume terms:\n{input_text}\n"
                "Return ONLY valid JSON with keys: technical_skills, tools_frameworks, soft_skills.",
                system="You are a resume parser. Return only valid JSON."
            )
            parsed = json.loads(raw.strip().strip("```json").strip("```"))
            samples.append(make_sample(instruction, input_text, json.dumps(parsed)))
            time.sleep(0.3)
        except Exception as e:
            print(f"  skip classify sample: {e}")
    return samples
 
 
