#  FUNCTION 7 — validate_job_role / validate_skills
# ══════════════════════════════════════════════════════════════════════════════
VALID_INPUTS   = ROLES + SKILLS
INVALID_INPUTS = [
    "asdfghjkl", "xyz123abc", "blahblah", "qwerty", "random stuff",
    "!!@@##", "hello world test", "aaaaaa", "123456", "notajob",
    "faketerm999", "gibberish input", "xyzzy", "lorum ipsum",
]
 
def gen_validate(n: int) -> list:
    samples = []
    instruction = (
        "Determine if the given input is a valid professional job role or technical skill. "
        "Reply with only True or False."
    )
    for _ in tqdm(range(n), desc="validate_job_role/skills"):
        is_valid   = random.random() > 0.4
        input_val  = random.choice(VALID_INPUTS if is_valid else INVALID_INPUTS)
        input_text = f"Input: {input_val}"
        output     = "True" if is_valid else "False"
        samples.append(make_sample(instruction, input_text, output))
    # no API call needed — rule-based is fine for validation training data
    return samples
 
 
# ── Main ──────────────────────────────────────────────────────────────────────
def main():
    all_samples = []
 
    print("\n🔄 Generating training data for all 7 functions...\n")
 
    all_samples += gen_evaluate_answer(SAMPLES_EACH)
    all_samples += gen_generate_questions(SAMPLES_EACH)
    all_samples += gen_single_question(SAMPLES_EACH)
    all_samples += gen_interview_summary(SAMPLES_EACH)
    all_samples += gen_extract_resume(SAMPLES_EACH)
    all_samples += gen_classify_skills(SAMPLES_EACH)
    all_samples += gen_validate(SAMPLES_EACH)   # rule-based, no API
 
    random.shuffle(all_samples)
 
    with open(OUTPUT_FILE, "w") as f:
        for sample in all_samples:
            f.write(json.dumps(sample) + "\n")
 
    print(f"\n✅ Done! Saved {len(all_samples)} samples to {OUTPUT_FILE}")
    print(f"   Breakdown: ~{SAMPLES_EACH} samples × 7 functions")
    print(f"\n→ Next: Upload {OUTPUT_FILE} to Google Colab and run step2_finetune.ipynb")
 
 
if __name__ == "__main__":
    main()